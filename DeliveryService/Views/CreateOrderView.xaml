<UserControl x:Class="DeliveryService.Views.CreateOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="#1E1E1E">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Заказы" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
            <TextBox Width="250" Height="30" Margin="20,0,0,0" 
                     Background="#2D2D2D" Foreground="White" BorderThickness="0"
                     VerticalContentAlignment="Center" Padding="10,0"
                     Tag="Поиск по клиенту, адресу..."/>
            <Button Content="+ Новый заказ" HorizontalAlignment="Right" Padding="15,5" 
                    Background="#353535" Foreground="White" BorderThickness="0"/>
        </DockPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <ComboBox Width="200" Height="35" Background="#2D2D2D" Foreground="White" SelectedIndex="0" Margin="0,0,10,0">
                <ComboBoxItem Content="Все статусы"/>
            </ComboBox>
            <ComboBox Width="200" Height="35" Background="#2D2D2D" Foreground="White" SelectedIndex="0">
                <ComboBoxItem Content="Все курьеры"/>
            </ComboBox>
        </StackPanel>

        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,20">
            <Border Background="#2D2D2D" Margin="0,0,10,0" Padding="15" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Всего сегодня" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="58" Foreground="White" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#2D2D2D" Margin="0,0,10,0" Padding="15" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="В пути" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="8" Foreground="#4A90E2" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#2D2D2D" Margin="0,0,10,0" Padding="15" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Ожидают курьера" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="3" Foreground="#F5A623" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#2D2D2D" Padding="15" CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Доставлено" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="47" Foreground="#7ED321" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <DataGrid Grid.Row="3" ItemsSource="{Binding Orders}" AutoGenerateColumns="False" 
                  Background="Transparent" BorderThickness="0" Foreground="White"
                  RowBackground="#252525" GridLinesVisibility="None" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="*"/>
                <DataGridTextColumn Header="Откуда → Куда" Binding="{Binding Route}" Width="2*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="Курьер" Binding="{Binding CourierName}" Width="*"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding Price}" Width="80"/>
                <DataGridTextColumn Header="Время" Binding="{Binding OrderTime}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>