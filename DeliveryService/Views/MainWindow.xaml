<Window x:Class="DeliveryService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeliveryManager" Height="800" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F9FAFB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <StackPanel>

                <Border Height="100" Background="#2563EB" Margin="0,0,0,10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🚚" FontSize="32" HorizontalAlignment="Center" Foreground="White"/>
                        <TextBlock Text="DeliveryManager" FontSize="16" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock Text="Система управления доставкой" FontSize="10" 
                           Foreground="#BFDBFE" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>


                <TextBlock Text="ОСНОВНОЕ" FontSize="11" FontWeight="SemiBold" 
                   Foreground="#9CA3AF" Margin="16,16,0,8"/>


                <Button Height="44" HorizontalAlignment="Stretch" Background="Transparent" 
                Cursor="Hand" Margin="8,2,8,2" Command="{Binding OpenDispatcherCommand}" Click="Button_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🗺️" FontSize="18" Width="32"/>
                                    <TextBlock Text="Диспетчерская" FontSize="14" Margin="8,0,0,0" Foreground="#6B7280"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E7EB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#D1D5DB"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>


                <Button Height="44" HorizontalAlignment="Stretch" Background="Transparent" 
                Cursor="Hand" Margin="8,2,8,2" Command="{Binding OpenOrderListCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="18" Width="32"/>
                                    <TextBlock Text="Заказы" FontSize="14" Margin="8,0,0,0" Foreground="#6B7280"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E7EB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#D1D5DB"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>


                <Button Height="44" HorizontalAlignment="Stretch" Background="Transparent" 
                Cursor="Hand" Margin="8,2,8,2" Command="{Binding OpenListCouriersCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🏃" FontSize="18" Width="32"/>
                                    <TextBlock Text="Курьеры" FontSize="14" Margin="8,0,0,0" Foreground="#6B7280"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E5E7EB"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#D1D5DB"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>


                <TextBlock Text="ДЕЙСТВИЯ" FontSize="11" FontWeight="SemiBold" 
                   Foreground="#9CA3AF" Margin="16,24,0,8"/>


                <Button Height="44" HorizontalAlignment="Stretch" Background="Transparent" 
                Cursor="Hand" Margin="8,2,8,2" Command="{Binding OpenNewOrderCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="➕" FontSize="18" Width="32" Foreground="#2563EB"/>
                                    <TextBlock Text="Новый заказ" FontSize="14" Margin="8,0,0,0" 
                                       Foreground="#2563EB" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#DBEAFE"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Height="44" HorizontalAlignment="Stretch" Background="Transparent" 
                Cursor="Hand" Margin="8,2,8,2" Command="{Binding OpenRegistrationCourierCommand}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="➕" FontSize="18" Width="32" Foreground="#2563EB"/>
                                    <TextBlock Text="Регистрация курьера" FontSize="14" Margin="8,0,0,0" 
                                        Foreground="#2563EB" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#DBEAFE"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>


                <Border Height="1" Background="#E5E7EB" Margin="12,30,12,0"/>


                <Border Margin="12,16" Background="#F3F4F6" CornerRadius="12" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Диспетчер" FontSize="13" FontWeight="SemiBold" 
                           Foreground="#111827" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="Online" FontSize="10" Foreground="#10B981" 
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <ContentControl
        Grid.Column="1"
        Content="{Binding CurrentView}"/>
        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Добро пожаловать" FontSize="28" FontWeight="Medium" 
                       Foreground="#111827" HorizontalAlignment="Center" Margin="0,0,0,5"/>

            <TextBlock Text="Выберите раздел в меню слева" FontSize="14" 
                       Foreground="#6B7280" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <UniformGrid Columns="2">
                <Button Style="{StaticResource MenuCardStyle}" Command="{Binding OpenDispatcherCommand}">
                    <StackPanel>
                        <TextBlock Text="🗺️" FontSize="42" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Диспетчерская" FontSize="16" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center"/>
                        <TextBlock Text="Карта и мониторинг" FontSize="11" Foreground="#9CA3AF" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuCardStyle}" Command="{Binding OpenOrderListCommand}">
                    <StackPanel>
                        <TextBlock Text="📋" FontSize="42" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Заказы" FontSize="16" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center"/>
                        <TextBlock Text="История и статусы" FontSize="11" Foreground="#9CA3AF" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuCardStyle}" Command="{Binding OpenListCouriersCommand}">
                    <StackPanel>
                        <TextBlock Text="🏃" FontSize="42" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                        <TextBlock Text="Курьеры" FontSize="16" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center"/>
                        <TextBlock Text="Список персонала" FontSize="11" Foreground="#9CA3AF" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuCardStyle}" Command="{Binding OpenNewOrderCommand}">
                    <StackPanel>
                        <TextBlock Text="➕" FontSize="42" Margin="0,0,0,20" HorizontalAlignment="Center" Foreground="#2563EB"/>
                        <TextBlock Text="Новый заказ" FontSize="16" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center"/>
                        <TextBlock Text="Оформить заявку" FontSize="11" Foreground="#9CA3AF" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

        </StackPanel>
    </Grid>
</Window>