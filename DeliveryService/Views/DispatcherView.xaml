<Window x:Class="DeliveryService.Views.DispatcherView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeliveryService.Views"
        mc:Ignorable="d"
        Title="DispatcherView" Height="800" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#F0F0F0">
            <TextBlock Text="место под карту" 
                       FontSize="16" 
                       Foreground="#999"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
        <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0" Grid.Column="1">
            <StackPanel Margin="15,20,15,20">
                <TextBlock Text="Активные заказы" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="#555"
                           Margin="0,0,0,10"/>
                <Border BorderBrush="#CCC" BorderThickness="1" 
                        CornerRadius="4" Padding="10" Margin="0,0,0,5"
                        Background="White">
                    <TextBlock Text="[Заказ #1]" FontSize="14" FontWeight="SemiBold"/>
                </Border>
                <Border BorderBrush="#CCC" BorderThickness="1" 
                        CornerRadius="4" Padding="10" Margin="0,0,0,20"
                        Background="White">
                    <TextBlock Text="[Заказ #2]" FontSize="14" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="Курьеры онлайн" 
                           FontSize="16" 
                           FontWeight="Bold"
                           Foreground="#555"
                           Margin="0,0,0,10"/>
                <Border BorderBrush="#CCC" BorderThickness="1" 
                        CornerRadius="4" Padding="10" Margin="0,0,0,5"
                        Background="White">
                    <Grid>
                        <TextBlock Text="Иван" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="свободен" 
                                   FontSize="14"
                                   Background="Green"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <Border BorderBrush="#CCC" BorderThickness="1" 
                        CornerRadius="4" Padding="10" Margin="0,0,0,5"
                        Background="White">
                    <Grid>
                        <TextBlock Text="Петр" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Text="занят" 
                                   FontSize="14"
                                   Background="Red"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
