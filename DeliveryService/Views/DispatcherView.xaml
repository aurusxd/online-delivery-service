<Window x:Class="DeliveryService.Views.DispatcherView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="DispatcherView" Height="800" Width="1200" Loaded="Window_Loaded">

    <Grid Background="#F9FAFB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">
            <wv2:WebView2 x:Name="Map"/>
        </Border>

        <Border Grid.Column="1" Background="White" BorderBrush="#E5E7EB" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="15,20">

                    <TextBlock Text="Диспетчерская" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

                    
                    <UniformGrid Columns="3" Margin="0,0,0,25">
                        <Border Background="#F3F4F6" CornerRadius="8" Padding="10" Margin="0,0,5,0">
                            <StackPanel>
                                <TextBlock Text="{Binding InTransitOrderCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="В пути" FontSize="11" Foreground="#374151" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F3F4F6" CornerRadius="8" Padding="10" Margin="2,0,2,0">
                            <StackPanel>
                                <TextBlock Text="{Binding NewOrderCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Новых" FontSize="11" Foreground="#374151" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F3F4F6" CornerRadius="8" Padding="10" Margin="5,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding CompletedOrderCount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Готово" FontSize="11" Foreground="#374151" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Text="АКТИВНЫЕ ЗАКАЗЫ" FontSize="12" FontWeight="Bold" Foreground="#000000" Margin="0,0,0,10"/>


                    <ItemsControl x:Name="ActiveOrdersItemsControl" ItemsSource="{Binding ActiveOrders}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectOrderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalContentAlignment="Stretch">

                                    <Border Background="White" 
                                    BorderBrush="#E5E7EB" 
                                    BorderThickness="1" 
                                    CornerRadius="8" 
                                    Padding="12" 
                                    Margin="0,0,0,8"
                                    Height="130">


                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                            Command="{Binding SelectOrderCommand,
                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Id, StringFormat='№{0}'}"
                                                   Foreground="#111827" 
                                                   FontWeight="Bold" 
                                                   FontSize="14"/>
                                                <TextBlock Text="{Binding Courier.Name, StringFormat='{}Курьер: {0}'}" 
                                                   FontSize="12" 
                                                   Foreground="#4B5563" 
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="Wrap"/>
                                                <StackPanel Visibility="{Binding Status,Converter={StaticResource converter},ConverterParameter=new}">
                                                    <ComboBox ItemsSource="{Binding DataContext.FreeCouriers, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      SelectedItem="{Binding DataContext.SelectedCourier, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      DisplayMemberPath="Name"
                                                      Margin="0,6,0,4"/>
                                                    <Button Content="Назначить"
                                                    Command="{Binding DataContext.AssignCourierCommand,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                                </StackPanel>

                                            </StackPanel>

                                            <Border Grid.Column="1" 
                                            VerticalAlignment="Center"
                                            Background="#DBEAFE" 
                                            CornerRadius="4" 
                                            Padding="8,4">
                                                <TextBlock Text="{Binding Status}" 
                                                   FontSize="10" 
                                                   Foreground="#1E40AF" 
                                                   FontWeight="Medium"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="КУРЬЕРЫ ОНЛАЙН" FontSize="12" FontWeight="Bold" Foreground="#000000" Margin="0,20,0,10"/>

                    <ListView x:Name="CouriersListView" ItemsSource="{Binding OnlineCouriers}" BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F3F4F6" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                        Command="{Binding DataContext.SelectCourierCommand,RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        

                                        <Border Width="32" Height="32" Background="#2563EB" CornerRadius="16" Margin="0,0,12,0">
                                            <TextBlock Text="К" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" 
                                                   Foreground="#111827" 
                                                   FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding IsActive}" FontSize="12" Foreground="#059669"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>