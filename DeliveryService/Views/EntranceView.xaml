<Window x:Class="DeliveryService.Views.EntranceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DeliveryService.Views"
        mc:Ignorable="d"
        Title="EntranceView" Height="650" Width="500">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Width="130" 
                Height="130" 
                Background="#2563EB" 
                CornerRadius="65" 
                Margin="0,0,0,20"
                HorizontalAlignment="Center">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🚚" FontSize="36" HorizontalAlignment="Center"/>
                <TextBlock Text="Delivery" FontSize="14" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                <TextBlock Text="Manager" FontSize="12" FontWeight="Bold" 
                           Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,0"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="1" 
                   Text="Вход" 
                   FontSize="32" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Имя:" 
                       FontSize="16"
                       Margin="0,0,0,5" HorizontalAlignment="Center"/>
            <TextBox Name="NameTextBox"
                     Text="{Binding CourierName}"
                     FontSize="18" 
                     Height="35"
                     Width="300"
                     HorizontalAlignment="Center"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,25">
            <TextBlock Text="Номер телефона:" 
                       FontSize="16"
                       Margin="0,0,0,5" HorizontalAlignment="Center"/>
            <TextBox Name="PhoneTextBox"
                     Text="{Binding CourierPhone}"
                     FontSize="18" 
                     Height="35"
                     Width="300"
                     HorizontalAlignment="Center"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="4" 
                x:Name="LoginButton"
                Content="Вход"
                Command="{Binding SaveCommand}"
                Width="300" 
                Height="45"
                FontSize="16"
                HorizontalAlignment="Center"
                Style="{StaticResource PrimaryButton}" 
                Margin="0,0,0,15"/>

        <Button Grid.Row="5" 
                Name="RegisterButton"
                Content="Зарегистрироваться"
                Command="{Binding SaveCommand}"
                Width="200"
                Height="30"
                FontSize="13"
                HorizontalAlignment="Center"
                Style="{StaticResource TextLinkButton}"/>
    </Grid>
</Window>