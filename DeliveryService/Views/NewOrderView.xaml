<Window x:Class="DeliveryService.Views.NewOrderView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:DeliveryService.Views"
        mc:Ignorable="d"
        Title="NewOrderView" Height="800" Width="1100">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ: ФОРМА -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="18,16">
                <TextBlock Text="Новый заказ" FontSize="16" FontWeight="SemiBold"
                       Foreground="Black" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right"
                    Width="28" Height="28" Background="White"
                    Foreground="Black" BorderThickness="0"
                    FontSize="14" Cursor="Hand"/>
            </Grid>

            <!-- Форма -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18,0,18,18">

                    <!-- Клиент -->
                    <TextBlock Text="КЛИЕНТ" FontSize="10" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Имя" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="Иванов Алексей"
                                 Foreground="Black" BorderBrush="#444"
                                 BorderThickness="1" Padding="10,8"
                                 FontSize="13"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Телефон" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                            <TextBox Text="+7 999 000-00-00"
                                 Foreground="Black" BorderBrush="#444"
                                 BorderThickness="1" Padding="10,8"
                                 FontSize="13"/>
                        </StackPanel>
                    </Grid>

                    <!-- Откуда -->
                    <TextBlock Text="ОТКУДА ЗАБРАТЬ" FontSize="10" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,8"/>
                    <TextBlock Text="Адрес" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <TextBox Text="ул. Ленина 12"
                             Foreground="Black" BorderBrush="#444"
                             BorderThickness="1" Padding="10,8,36,8"
                             FontSize="13"/>
                        <TextBlock Text="📍" HorizontalAlignment="Right"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    </Grid>
                    <TextBlock Text="или кликните на карте →" FontSize="11"
                           Foreground="#4A90D9" Cursor="Hand" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="Широта: 55.7558"
                             Foreground="#666"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="8,6" FontSize="12" IsReadOnly="True"/>
                        <TextBox Grid.Column="2" Text="Долгота: 37.6173"
                             Foreground="#666"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="8,6" FontSize="12" IsReadOnly="True"/>
                    </Grid>

                    <!-- Разделитель -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Separator Grid.Column="0" Background="#444" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="↓" Foreground="#666"
                               FontSize="16" Margin="12,0"/>
                        <Separator Grid.Column="2" Background="#444" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Куда -->
                    <TextBlock Text="КУДА ДОСТАВИТЬ" FontSize="10" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,8"/>
                    <TextBlock Text="Адрес" FontSize="11" Foreground="#888" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <TextBox Text="пр. Мира 47" 
                             Foreground="Black" BorderBrush="#444"
                             BorderThickness="1" Padding="10,8,36,8"
                             FontSize="13"/>
                        <TextBlock Text="🏁" HorizontalAlignment="Right"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    </Grid>
                    <TextBlock Text="или кликните на карте →" FontSize="11"
                           Foreground="#4A90D9" Cursor="Hand" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="Широта: 55.7800"
                             Foreground="#666"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="8,6" FontSize="12" IsReadOnly="True"/>
                        <TextBox Grid.Column="2" Text="Долгота: 37.6500"
                             Foreground="#666"
                             BorderBrush="#444" BorderThickness="1"
                             Padding="8,6" FontSize="12" IsReadOnly="True"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Кнопки -->
            <Grid Grid.Row="2" Margin="18,12,18,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>
                <Button Grid.Column="2" Content="Создать заказ"
                    Style="{StaticResource PrimaryButton}" Height="40"/>
            </Grid>
        </Grid>

        <!-- ПРАВАЯ ПАНЕЛЬ: КАРТА -->
        <Grid Grid.Column="0" Background="#E8EDE8">
            <wv2:WebView2 x:Name="Map"/>
        </Grid>
    </Grid>
</Window>
